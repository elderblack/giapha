# Sao chép thành .env.local — Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Bắt buộc cho Edge Functions (JWT legacy "anon"). Không thay bằng sb_publishable_...
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional — canonical site URL cho auth/email (mặc định browser origin).
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Publishable chỉ dùng được cho một số API; gọi functions.invoke vẫn cần anon JWT phía trên.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# SMS (Phone OTP): Supabase Dashboard → Authentication → Phone → bật + cấu hình Twilio/MessageBird…
# Không cần biến môi trường thêm cho OTP; chỉ cần bật provider trên cloud.

